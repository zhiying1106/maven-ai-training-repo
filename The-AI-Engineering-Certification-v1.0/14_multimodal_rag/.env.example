# Copy this file to `.env` (same folder as the notebook) and fill in your key.
# The notebook loads it automatically with python-dotenv. `.env` is git-ignored.

# Required (default provider is OpenAI):
OPENAI_API_KEY=your_openai_api_key_here

# Optional — only if you switch providers (also change VLM_MODEL/EMBED_MODEL in the notebook):
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# GOOGLE_API_KEY=your_google_api_key_here

# Optional — override the default models without editing the notebook:
# VLM_MODEL=openai:gpt-5.6-luna
# EMBED_MODEL=text-embedding-3-small
